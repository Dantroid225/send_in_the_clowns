# .gitattributes — Send in the Clowns
# Purpose: Normalize line endings and mark large binary asset types for Git LFS.
# Created: 2026-06-30 | Last Modified: 2026-06-30
# Note: LFS tracking is declared now so post-MVP Blender/texture work doesn't
#       bloat the repo. Run `git lfs install` before adding any tracked binary.

# ── Line endings ────────────────────────────────────────────────────────────
* text=auto eol=lf
*.cs text eol=lf
*.md text eol=lf
*.json text eol=lf
*.meta text eol=lf
*.asset text eol=lf
*.unity text eol=lf
*.prefab text eol=lf

# ── PowerShell stays CRLF on Windows ────────────────────────────────────────
*.ps1 text eol=crlf

# ── Git LFS (post-MVP asset pipeline; declared early) ───────────────────────
*.blend filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
