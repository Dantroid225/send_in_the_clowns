# .gitignore — Send in the Clowns
# Purpose: Keep build artifacts, secrets, and large binaries out of the repo.
# Created: 2026-06-30 | Last Modified: 2026-06-30
# Related: .gitattributes, CLAUDE.md §Security

# ── Bootstrap / upload artifacts ───────────────────────────────────────────
*.zip
files.zip

# ── Secrets (no backend at MVP, but never leak one if added) ────────────────
.env
.env.*
*.secret
.secrets/

# ── Unity generated folders (project-name-agnostic — matches any project ────
#    under unity/, so it covers unity_clowns/ AND the current
#    unity/Send_in_the_Clowns/ the user created). Source (Assets/, Packages/,
#    ProjectSettings/) is intentionally NOT ignored — but is not committed by
#    the bootstrap; committing the Unity project is a Phase 0 decision.
unity/*/Library/
unity/*/Temp/
unity/*/Obj/
unity/*/Build/
unity/*/Builds/
unity/*/Logs/
unity/*/UserSettings/
unity/*/MemoryCaptures/
unity/*/Recordings/
unity/*/.vs/
unity/*/*.csproj
unity/*/*.sln
unity/*/*.user
unity/*/*.userprefs
unity/*/*.pidb
unity/*/*.booproj
unity/*/*.suo
unity/*/*.unityproj
unity/*/*.svd
unity/*/*.pdb.meta
unity/*/*.apk
unity/*/*.aab
unity/*/*.unitypackage
unity/*/crashlog/

# ── Python (workspace venv / utility scripts) ───────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/

# ── Node (if any tooling lands) ─────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Blender autosave ────────────────────────────────────────────────────────
*.blend1
*.blend2

# ── OS / editor cruft ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*~
